# HappyCake US — Environment configuration
# Copy this file to .env and fill in real values. NEVER commit .env.

# ── Required ────────────────────────────────────────────────────────────────

# Hosted MCP endpoint and per-team bearer token (Steppe Business Club hackathon)
MCP_BASE_URL=https://www.steppebusinessclub.com/api/mcp
MCP_TEAM_TOKEN=replace-with-your-private-team-token

# Telegram owner bot — create via @BotFather, paste token here
TELEGRAM_OWNER_BOT_TOKEN=replace-with-bot-token-from-botfather
TELEGRAM_OWNER_CHAT_ID=replace-with-numeric-chat-id

# Public webhook URL for inbound channel webhooks (cloudflared/ngrok prints this)
PUBLIC_BASE_URL=https://your-tunnel-url.example.com

# ── Optional channel webhooks (Meta sandbox) ────────────────────────────────

WHATSAPP_VERIFY_TOKEN=local-dev-verify-token
WHATSAPP_APP_SECRET=local-dev-app-secret
INSTAGRAM_VERIFY_TOKEN=local-dev-verify-token
INSTAGRAM_APP_SECRET=local-dev-app-secret

# ── Defaults ────────────────────────────────────────────────────────────────

ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./happycake.sqlite
WEB_PORT=8000
GATEWAY_PORT=8001

# Claude Code CLI binary (defaults to "claude" on PATH)
CLAUDE_CLI=claude
CLAUDE_TIMEOUT_SECONDS=45
